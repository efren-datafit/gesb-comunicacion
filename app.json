{
  "expo": {
    "name": "GESB Comunicación",
    "slug": "gesb-comunicacion",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "gesbcomunicacion",
    "plugins": [
      "expo-notifications"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.datafit.gesbcomunicacion",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.datafit.gesbcomunicacion",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#820010"
      }
    },
    "extra": {
      "eas": {
        "projectId": "21d1d104-d5ce-4dbd-bef8-e15b84ea6971"
      }
    },
    "owner": "devdatafit"
  }
}
